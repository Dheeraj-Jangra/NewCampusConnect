datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id             String          @id @default(uuid())
  email          String          @unique
  username       String?         @unique
  password       String
  name           String
  role           String          // "student" | "professor" | "admin"
  isApproved     Boolean         @default(true)
  resetToken     String?
  resetTokenExpiry DateTime?
  createdAt      DateTime        @default(now())
  
  // Relations
  notices        Notice[]
  classes        Class[]
  materials      StudyMaterial[]
  chatMessages   ChatMessage[]
}

model Notice {
  id        String   @id @default(uuid())
  title     String
  category  String
  author    String
  content   String
  timestamp DateTime @default(now())
  
  // Optional linkage to User
  authorId  String?
  user      User?    @relation(fields: [authorId], references: [id], onDelete: SetNull)
}

model Class {
  id        String   @id @default(uuid())
  subject   String
  professor String
  time      String   // "HH:MM"
  duration  String   // in minutes, e.g., "60"
  room      String
  link      String
  timestamp DateTime @default(now())
  
  // Optional linkage to User
  professorId String?
  user        User?    @relation(fields: [professorId], references: [id], onDelete: SetNull)
}

model StudyMaterial {
  id        String   @id @default(uuid())
  title     String
  course    String
  type      String   // e.g., "pdf", "zip"
  size      String   // e.g., "2.4 MB"
  author    String
  fileName  String   // local file name stored in server/uploads
  timestamp DateTime @default(now())
  
  // Optional linkage to User
  authorId  String?
  user      User?    @relation(fields: [authorId], references: [id], onDelete: SetNull)
}

model ChatMessage {
  id        String   @id @default(uuid())
  channel   String   // references a channel id from the channels config
  sender    String
  role      String   // "student" | "faculty"
  avatarBg  String
  content   String
  time      String   // format "3:42 PM"
  timestamp DateTime @default(now())
  
  // Optional linkage to User
  senderId  String?
  user      User?    @relation(fields: [senderId], references: [id], onDelete: SetNull)
}
