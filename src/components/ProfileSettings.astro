---
// Profile Settings Component
---

<div id="profile-settings-root" class="w-full flex-1 flex flex-col gap-6 opacity-0 translate-y-4 transition-all duration-500">

  <!-- Subheader -->
  <div class="flex flex-col md:flex-row md:items-center justify-between gap-4 border-b border-hairline pb-6">
    <div>
      <h2 class="display-md text-ink">Profile Settings</h2>
      <p class="body-sm text-muted">Manage your account information and security preferences.</p>
    </div>
  </div>

  <!-- Content Grid -->
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 items-start">

    <!-- Profile Info Card -->
    <div class="bg-surface-card border border-hairline rounded-lg p-6 flex flex-col gap-5 animated-mount">
      <div class="flex items-center justify-between border-b border-hairline pb-3">
        <h3 class="title-md text-ink">Account Details</h3>
        <span class="px-2 py-0.5 text-[9px] font-bold uppercase tracking-wider text-timeline-read border border-timeline-read/20 rounded-pill" style="background: rgba(159, 187, 224, 0.12);">Read-only</span>
      </div>

      <div class="flex flex-col gap-4" id="profile-info-display">
        <div class="flex items-center gap-4 p-3 bg-canvas-soft border border-hairline rounded-lg">
          <div id="profile-avatar" class="w-14 h-14 rounded-full bg-primary/10 border border-primary/20 text-primary font-bold flex items-center justify-center text-lg flex-shrink-0">?</div>
          <div class="flex flex-col gap-0.5">
            <span id="profile-display-name" class="title-sm text-ink">Loading...</span>
            <span id="profile-display-role" class="text-xs text-muted">—</span>
            <span id="profile-display-email" class="text-xs text-body">—</span>
          </div>
        </div>

        <div class="grid grid-cols-2 gap-3">
          <div class="flex flex-col gap-0.5 p-3 bg-canvas-soft/50 border border-hairline rounded-lg">
            <span class="text-[10px] font-bold uppercase tracking-wider text-muted">Email</span>
            <span id="profile-email-value" class="text-sm text-ink font-semibold truncate">—</span>
          </div>
          <div class="flex flex-col gap-0.5 p-3 bg-canvas-soft/50 border border-hairline rounded-lg">
            <span class="text-[10px] font-bold uppercase tracking-wider text-muted">Username</span>
            <span id="profile-username-value" class="text-sm text-ink font-semibold truncate">—</span>
          </div>
          <div class="flex flex-col gap-0.5 p-3 bg-canvas-soft/50 border border-hairline rounded-lg">
            <span class="text-[10px] font-bold uppercase tracking-wider text-muted">Roll Number</span>
            <span id="profile-rollnumber-value" class="text-sm text-ink font-semibold truncate">—</span>
          </div>
          <div class="flex flex-col gap-0.5 p-3 bg-canvas-soft/50 border border-hairline rounded-lg">
            <span class="text-[10px] font-bold uppercase tracking-wider text-muted">Role</span>
            <span id="profile-role-value" class="text-sm text-ink font-semibold">—</span>
          </div>
          <div class="flex flex-col gap-0.5 p-3 bg-canvas-soft/50 border border-hairline rounded-lg">
            <span class="text-[10px] font-bold uppercase tracking-wider text-muted">Member Since</span>
            <span id="profile-created-value" class="text-sm text-ink font-semibold">—</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Edit Profile Card -->
    <div class="bg-surface-card border border-hairline rounded-lg p-6 flex flex-col gap-5 animated-mount" style="animation-delay: 100ms;">
      <div class="flex items-center justify-between border-b border-hairline pb-3">
        <h3 class="title-md text-ink">Edit Profile</h3>
        <span class="px-2 py-0.5 text-[9px] font-bold uppercase tracking-wider text-timeline-done border border-timeline-done/20 rounded-pill" style="background: rgba(192, 133, 50, 0.12);">Editable</span>
      </div>

      <form id="profile-form" class="flex flex-col gap-4">
        <div class="flex flex-col gap-1.5">
          <label for="profile-name" class="text-xs font-semibold text-body-strong">Full Name</label>
          <input type="text" id="profile-name" placeholder="Your full name" required class="w-full px-3 py-2 bg-canvas-soft border border-hairline rounded-md text-sm text-ink focus:outline-none focus:border-primary transition-all duration-200" />
        </div>

        <div class="flex flex-col gap-1.5">
          <label for="profile-username" class="text-xs font-semibold text-body-strong">Username</label>
          <div class="flex gap-2 items-stretch">
            <input type="text" id="profile-username" placeholder="e.g. john_doe" class="flex-1 min-w-0 px-3 py-2 bg-canvas-soft border border-hairline rounded-md text-sm text-ink focus:outline-none focus:border-primary transition-all duration-200" />
            <button type="button" id="generate-username-btn" class="btn-secondary btn-press text-[10px] font-bold uppercase tracking-wider px-2.5 py-2 shrink-0 hover:scale-105 transition-all duration-200">
              Generate
            </button>
          </div>
          <span class="text-[10px] text-muted">3-30 characters. Letters, numbers, underscores, and hyphens only.</span>
        </div>

        <div class="flex flex-col gap-1.5">
          <label for="profile-rollnumber" class="text-xs font-semibold text-body-strong">Roll Number</label>
          <input type="text" id="profile-rollnumber" placeholder="e.g. 2024CS001" class="w-full px-3 py-2 bg-canvas-soft border border-hairline rounded-md text-sm text-ink focus:outline-none focus:border-primary transition-all duration-200" />
          <span class="text-[10px] text-muted">2-20 characters. Your student or faculty roll number.</span>
        </div>

        <button type="submit" id="profile-save-btn" class="btn-primary btn-press ripple-container w-full mt-2 flex items-center justify-center gap-2">
          <span>Save Changes</span>
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="w-3.5 h-3.5"><path d="M20 6 9 17l-5-5"/></svg>
        </button>
      </form>
    </div>

    <!-- Change Password Card (full width below) -->
    <div class="lg:col-span-2 bg-surface-card border border-hairline rounded-lg p-6 flex flex-col gap-5 animated-mount" style="animation-delay: 200ms;">
      <div class="flex items-center justify-between border-b border-hairline pb-3">
        <h3 class="title-md text-ink">Change Password</h3>
        <span class="px-2 py-0.5 text-[9px] font-bold uppercase tracking-wider text-timeline-thinking border border-timeline-thinking/20 rounded-pill" style="background: rgba(223, 168, 143, 0.12);">Security</span>
      </div>

      <form id="password-form" class="grid grid-cols-1 md:grid-cols-3 gap-4 items-end">
        <div class="flex flex-col gap-1.5">
          <label for="pass-current" class="text-xs font-semibold text-body-strong">Current Password</label>
          <div class="relative">
            <input type="password" id="pass-current" required placeholder="••••••••" class="w-full px-3 py-2 pr-10 bg-canvas-soft border border-hairline rounded-md text-sm text-ink focus:outline-none focus:border-primary transition-all duration-200" />
            <button type="button" class="password-toggle absolute right-1.5 top-1/2 -translate-y-1/2 p-1.5 text-muted hover:text-ink transition-colors duration-200 rounded-md hover:bg-canvas-soft/80" data-target="pass-current" tabindex="-1">
              <svg class="eye-closed" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"/><circle cx="12" cy="12" r="3"/></svg>
              <svg class="eye-open hidden" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9.88 9.88a3 3 0 1 0 4.24 4.24"/><path d="M10.73 5.08A10.43 10.43 0 0 1 12 5c7 0 10 7 10 7a13.16 13.16 0 0 1-1.67 2.68"/><path d="M6.61 6.61A13.53 13.53 0 0 0 2 12s3 7 10 7a9.74 9.74 0 0 0 5.39-1.61"/><line x1="2" x2="22" y1="2" y2="22"/></svg>
            </button>
          </div>
        </div>
        <div class="flex flex-col gap-1.5">
          <label for="pass-new" class="text-xs font-semibold text-body-strong">New Password</label>
          <div class="relative">
            <input type="password" id="pass-new" required placeholder="Min. 8 characters" class="w-full px-3 py-2 pr-10 bg-canvas-soft border border-hairline rounded-md text-sm text-ink focus:outline-none focus:border-primary transition-all duration-200" />
            <button type="button" class="password-toggle absolute right-1.5 top-1/2 -translate-y-1/2 p-1.5 text-muted hover:text-ink transition-colors duration-200 rounded-md hover:bg-canvas-soft/80" data-target="pass-new" tabindex="-1">
              <svg class="eye-closed" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"/><circle cx="12" cy="12" r="3"/></svg>
              <svg class="eye-open hidden" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9.88 9.88a3 3 0 1 0 4.24 4.24"/><path d="M10.73 5.08A10.43 10.43 0 0 1 12 5c7 0 10 7 10 7a13.16 13.16 0 0 1-1.67 2.68"/><path d="M6.61 6.61A13.53 13.53 0 0 0 2 12s3 7 10 7a9.74 9.74 0 0 0 5.39-1.61"/><line x1="2" x2="22" y1="2" y2="22"/></svg>
            </button>
          </div>
        </div>
        <button type="submit" id="password-change-btn" class="btn-primary btn-press ripple-container w-full flex items-center justify-center gap-2 h-[38px]">
          <span>Update Password</span>
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="w-3.5 h-3.5"><rect width="18" height="11" x="3" y="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
        </button>
      </form>
    </div>

  </div>

    <!-- Sign Out Card -->
    <div class="bg-surface-card border border-hairline rounded-lg p-6 flex flex-col gap-4 animated-mount lg:col-span-2" style="animation-delay: 300ms;">
      <button id="profile-signout-btn" class="btn-secondary btn-press w-full h-10 flex items-center justify-center gap-2 border border-hairline hover:border-semantic-error/40 hover:text-semantic-error hover:bg-semantic-error/5 transition-all duration-200">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-3.5 h-3.5"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" x2="9" y1="12" y2="12"/></svg>
        <span class="text-xs font-bold uppercase tracking-wider">Sign Out</span>
      </button>
    </div>

  </div>
</div>

<script>
  import { API_BASE } from '../lib/api';
  const PROFILE_URL = `${API_BASE}/api/auth/profile`;
  const PASSWORD_URL = `${API_BASE}/api/auth/password`;

  const escapeHtml = (str: string) => {
    if (!str) return '';
    const map: Record<string, string> = { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#x27;', '/': '&#x2F;' };
    return String(str).replace(/[&<>"'/]/g, (c) => map[c] || c);
  };

  const getAuthHeaders = () => {
    const token = localStorage.getItem('cc-token');
    const headers: Record<string, string> = { 'Content-Type': 'application/json' };
    if (token) headers['Authorization'] = `Bearer ${token}`;
    return headers;
  };

  const loadProfile = async () => {
    const userStr = localStorage.getItem('cc-user');
    if (!userStr) return;

    try {
      const user = JSON.parse(userStr);

      // Set avatar initial
      const avatar = document.getElementById('profile-avatar');
      if (avatar) {
        const initials = user.name ? user.name.split(' ').map((n: string) => n[0]).join('').substring(0, 2).toUpperCase() : '?';
        avatar.textContent = initials;
      }

      // Display fields
      const setText = (id: string, val: string) => {
        const el = document.getElementById(id);
        if (el) el.textContent = val || '—';
      };
      setText('profile-display-name', user.name || '—');
      setText('profile-display-role', user.role ? user.role.charAt(0).toUpperCase() + user.role.slice(1) : '—');
      setText('profile-display-email', user.email || '—');
      setText('profile-email-value', user.email || '—');
      setText('profile-username-value', user.username || '—');
      setText('profile-rollnumber-value', user.rollNumber || '—');
      setText('profile-role-value', user.role ? user.role.charAt(0).toUpperCase() + user.role.slice(1) : '—');

      // Pre-fill edit form
      const nameInput = document.getElementById('profile-name') as HTMLInputElement;
      const usernameInput = document.getElementById('profile-username') as HTMLInputElement;
      const rollNumberInput = document.getElementById('profile-rollnumber') as HTMLInputElement;
      if (nameInput) nameInput.value = user.name || '';
      if (usernameInput) usernameInput.value = user.username || '';
      if (rollNumberInput) rollNumberInput.value = user.rollNumber || '';

      // Try to fetch fresh profile from server for more data (like createdAt)
      try {
        const res = await fetch(`${API_BASE}/api/auth/me`, { headers: getAuthHeaders() });
        if (res.ok) {
          const profile = await res.json();
          if (profile.createdAt) {
            const date = new Date(profile.createdAt);
            setText('profile-created-value', date.toLocaleDateString('en-US', { month: 'long', year: 'numeric' }));
          }
          if (profile.username) {
            setText('profile-username-value', profile.username);
            if (usernameInput) usernameInput.value = profile.username || '';
          }
          if (profile.rollNumber) {
            setText('profile-rollnumber-value', profile.rollNumber);
            if (rollNumberInput) rollNumberInput.value = profile.rollNumber || '';
          }
        }
      } catch {}
    } catch {}
  };

  // Profile form submit
  const setupProfileForm = () => {
    const form = document.getElementById('profile-form') as HTMLFormElement;
    if (!form) return;

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const nameInput = document.getElementById('profile-name') as HTMLInputElement;
      const usernameInput = document.getElementById('profile-username') as HTMLInputElement;
      const rollNumberInput = document.getElementById('profile-rollnumber') as HTMLInputElement;
      const saveBtn = document.getElementById('profile-save-btn') as HTMLButtonElement;
      if (!nameInput || !saveBtn) return;

      const payload: Record<string, string> = { name: nameInput.value.trim() };
      if (usernameInput && usernameInput.value.trim()) {
        payload.username = usernameInput.value.trim();
      }
      if (rollNumberInput && rollNumberInput.value.trim()) {
        payload.rollNumber = rollNumberInput.value.trim();
      }

      saveBtn.disabled = true;
      saveBtn.innerHTML = `<span>Saving...</span>`;

      try {
        const res = await fetch(PROFILE_URL, {
          method: 'PUT',
          headers: getAuthHeaders(),
          body: JSON.stringify(payload),
        });
        const data = await res.json();

        if (res.ok) {
          // Update localStorage user
          const userStr = localStorage.getItem('cc-user');
          if (userStr) {
            const user = JSON.parse(userStr);
            user.name = data.user.name;
            user.username = data.user.username;
            user.rollNumber = data.user.rollNumber;
            localStorage.setItem('cc-user', JSON.stringify(user));
          }
          // Update token
          if (data.token) {
            localStorage.setItem('cc-token', data.token);
          }

          window.dispatchEvent(new CustomEvent('cc-toast-alert', {
            detail: { message: 'Profile updated successfully!', type: 'success' }
          }));

          // Re-load display and notify navbar
          await loadProfile();
          window.dispatchEvent(new CustomEvent('cc-login-success'));

          saveBtn.innerHTML = `<span>Saved!</span> <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="w-3.5 h-3.5 text-semantic-success"><path d="M20 6 9 17l-5-5"/></svg>`;
          setTimeout(() => {
            saveBtn.disabled = false;
            saveBtn.innerHTML = `<span>Save Changes</span> <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="w-3.5 h-3.5"><path d="M20 6 9 17l-5-5"/></svg>`;
          }, 1500);
        } else {
          throw new Error(data.error || 'Failed to update profile');
        }
      } catch (err: any) {
        window.dispatchEvent(new CustomEvent('cc-toast-alert', {
          detail: { message: err.message, type: 'error' }
        }));
        saveBtn.disabled = false;
        saveBtn.innerHTML = `<span>Save Changes</span> <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="w-3.5 h-3.5"><path d="M20 6 9 17l-5-5"/></svg>`;
      }
    });
  };

  // Password form submit
  const setupPasswordForm = () => {
    const form = document.getElementById('password-form') as HTMLFormElement;
    if (!form) return;

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const currentInput = document.getElementById('pass-current') as HTMLInputElement;
      const newInput = document.getElementById('pass-new') as HTMLInputElement;
      const submitBtn = document.getElementById('password-change-btn') as HTMLButtonElement;
      if (!currentInput || !newInput || !submitBtn) return;

      const currentPassword = currentInput.value;
      const newPassword = newInput.value;

      if (!currentPassword || !newPassword) return;
      if (newPassword.length < 8) {
        window.dispatchEvent(new CustomEvent('cc-toast-alert', {
          detail: { message: 'New password must be at least 8 characters', type: 'error' }
        }));
        return;
      }

      submitBtn.disabled = true;
      submitBtn.innerHTML = `<span>Updating...</span>`;

      try {
        const res = await fetch(PASSWORD_URL, {
          method: 'PUT',
          headers: getAuthHeaders(),
          body: JSON.stringify({ currentPassword, newPassword }),
        });
        const data = await res.json();

        if (res.ok) {
          window.dispatchEvent(new CustomEvent('cc-toast-alert', {
            detail: { message: 'Password changed successfully!', type: 'success' }
          }));
          form.reset();
          submitBtn.innerHTML = `<span>Updated!</span> <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="w-3.5 h-3.5 text-semantic-success"><path d="M20 6 9 17l-5-5"/></svg>`;
          setTimeout(() => {
            submitBtn.disabled = false;
            submitBtn.innerHTML = `<span>Update Password</span> <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="w-3.5 h-3.5"><rect width="18" height="11" x="3" y="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>`;
          }, 1500);
        } else {
          throw new Error(data.error || 'Failed to change password');
        }
      } catch (err: any) {
        window.dispatchEvent(new CustomEvent('cc-toast-alert', {
          detail: { message: err.message, type: 'error' }
        }));
        submitBtn.disabled = false;
        submitBtn.innerHTML = `<span>Update Password</span> <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="w-3.5 h-3.5"><rect width="18" height="11" x="3" y="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>`;
      }
    });
  };

  // Generate username button
  const setupGenerateUsername = () => {
    const btn = document.getElementById('generate-username-btn');
    const usernameInput = document.getElementById('profile-username') as HTMLInputElement;
    if (!btn || !usernameInput) return;

    btn.addEventListener('click', async () => {
      btn.setAttribute('disabled', 'true');
      btn.textContent = 'Generating...';

      try {
        const res = await fetch(`${API_BASE}/api/auth/generate-username`, {
          method: 'POST',
          headers: getAuthHeaders(),
        });
        const data = await res.json();

        if (res.ok && data.username) {
          usernameInput.value = data.username;
          window.dispatchEvent(new CustomEvent('cc-toast-alert', {
            detail: { message: `Username generated: ${data.username}`, type: 'success' }
          }));
        } else {
          throw new Error(data.error || 'Failed to generate username');
        }
      } catch (err: any) {
        window.dispatchEvent(new CustomEvent('cc-toast-alert', {
          detail: { message: err.message, type: 'error' }
        }));
      } finally {
        btn.removeAttribute('disabled');
        btn.textContent = 'Generate';
      }
    });
  };

  // Sign out handler
  const setupSignOut = () => {
    const btn = document.getElementById('profile-signout-btn');
    if (!btn) return;
    btn.addEventListener('click', () => {
      localStorage.removeItem('cc-token');
      localStorage.removeItem('cc-user');
      localStorage.removeItem('cc-active-role');
      window.dispatchEvent(new CustomEvent('cc-go-home'));
    });
  };

  const initProfile = () => {
    const root = document.getElementById('profile-settings-root');
    if (!root) return;

    loadProfile();
    setupProfileForm();
    setupPasswordForm();
    setupGenerateUsername();
    setupSignOut();

    setTimeout(() => {
      root.style.opacity = '1';
      root.style.transform = 'translateY(0)';
    }, 100);
  };

  window.addEventListener('load', initProfile);
  window.addEventListener('cc-tab-active-profile', initProfile);

</script>
