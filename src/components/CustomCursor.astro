---
// Custom Cursor Component
---

<div id="custom-cursor-dot" class="fixed top-0 left-0 w-2 h-2 bg-primary rounded-full pointer-events-none z-9999 mix-blend-difference hidden md:block" style="transform: translate3d(-100px, -100px, 0); transition: width 0.2s, height 0.2s, background-color 0.2s;"></div>
<div id="custom-cursor-ring" class="fixed top-0 left-0 w-8 h-8 border border-ink rounded-full pointer-events-none z-9998 hidden md:block" style="transform: translate3d(-100px, -100px, 0); margin-left: -12px; margin-top: -12px; transition: transform 0.1s cubic-bezier(0.1, 0.8, 0.3, 1), border-color 0.2s, background-color 0.2s, width 0.2s, height 0.2s, margin-left 0.2s, margin-top 0.2s;"></div>

<script>
  // Run on client side
  const dot = document.getElementById('custom-cursor-dot');
  const ring = document.getElementById('custom-cursor-ring');
  
  if (dot && ring) {
    let mouseX = -100;
    let mouseY = -100;
    let ringX = -100;
    let ringY = -100;
    let isHovering = false;
    let isMobile = false;

    // Detect touch device
    if (window.matchMedia('(max-width: 768px)').matches || ('ontouchstart' in window) || (navigator.maxTouchPoints > 0)) {
      isMobile = true;
      dot.style.display = 'none';
      ring.style.display = 'none';
    }

    if (!isMobile) {
      window.addEventListener('mousemove', (e) => {
        mouseX = e.clientX;
        mouseY = e.clientY;
        
        // Instant position for the inner dot
        dot.style.transform = `translate3d(${mouseX - 4}px, ${mouseY - 4}px, 0)`;
        
        // Show cursor elements once mouse moves
        dot.classList.remove('opacity-0');
        ring.classList.remove('opacity-0');
      });

      // Lerp / Interpolate outer ring coordinates
      const render = () => {
        // Slow outer ring follow
        ringX += (mouseX - ringX) * 0.18;
        ringY += (mouseY - ringY) * 0.18;

        ring.style.transform = `translate3d(${ringX}px, ${ringY}px, 0)`;
        requestAnimationFrame(render);
      };
      
      requestAnimationFrame(render);

      // Mouse down / click animation
      window.addEventListener('mousedown', () => {
        ring.classList.add('cursor-click-active');
        dot.style.transform = `translate3d(${mouseX - 4}px, ${mouseY - 4}px, 0) scale(0.5)`;
      });

      window.addEventListener('mouseup', () => {
        ring.classList.remove('cursor-click-active');
        dot.style.transform = `translate3d(${mouseX - 4}px, ${mouseY - 4}px, 0) scale(1)`;
      });

      // Hover bindings for dynamic elements
      const updateHoverBindings = () => {
        const hoverables = document.querySelectorAll('a, button, input[type="submit"], input[type="button"], select, textarea, input[type="text"], input[type="time"], .hover-interactive, [role="button"]');
        
        hoverables.forEach((el) => {
          // Prevent duplicates
          if (el.getAttribute('data-cursor-bound')) return;
          el.setAttribute('data-cursor-bound', 'true');

          el.addEventListener('mouseenter', () => {
            isHovering = true;
            ring.classList.add('cursor-hover-active');
            dot.style.backgroundColor = 'var(--color-primary)';
            
            // If it is a text input, make cursor look like an I-Beam
            if (el.tagName === 'INPUT' && (el as HTMLInputElement).type === 'text' || el.tagName === 'TEXTAREA') {
              ring.style.width = '6px';
              ring.style.height = '24px';
              ring.style.borderRadius = '2px';
              ring.style.marginLeft = '1px';
              ring.style.marginTop = '-12px';
            }
          });

          el.addEventListener('mouseleave', () => {
            isHovering = false;
            ring.classList.remove('cursor-hover-active');
            dot.style.backgroundColor = 'var(--color-primary)';
            
            // Restore default ring shape
            ring.style.width = '32px';
            ring.style.height = '32px';
            ring.style.borderRadius = '9999px';
            ring.style.marginLeft = '-12px';
            ring.style.marginTop = '-12px';
          });
        });
      };

      // Run initial binding and also set up observer for dynamic elements (SPA transitions)
      updateHoverBindings();
      
      const observer = new MutationObserver(() => {
        updateHoverBindings();
      });
      observer.observe(document.body, { childList: true, subtree: true });
    }
  }
</script>
