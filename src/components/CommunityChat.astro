---
// Community Chat Component
---

<div id="community-chat-root" class="w-full flex-1 flex flex-col md:flex-row bg-surface-card border border-hairline rounded-lg h-[550px] overflow-hidden select-none opacity-0 translate-y-4 transition-all duration-500">
  
  <!-- Sidebar: Channel Selector -->
  <div class="w-full md:w-60 border-r border-hairline bg-canvas-soft/50 flex flex-col h-1/3 md:h-full flex-shrink-0">
    <div class="p-4 border-b border-hairline flex items-center justify-between">
      <span class="text-xs font-bold uppercase tracking-wider text-ink">Community Channels</span>
      <span class="flex h-2 w-2 relative">
        <span class="animate-ping-slow absolute inline-flex h-full w-full rounded-full bg-primary opacity-75"></span>
        <span class="relative inline-flex rounded-full h-2 w-2 bg-primary"></span>
      </span>
    </div>
    
    <div class="flex-1 overflow-y-auto p-2 flex flex-row md:flex-col gap-1.5 scrollbar-thin" id="channel-list">
      <button data-channel="general" class="channel-btn active w-full px-3 py-2 text-left text-xs font-semibold rounded-md flex items-center gap-2 transition-all duration-200">
        <span class="text-muted">#</span> general-chat
      </button>
      <button data-channel="q-and-a" class="channel-btn w-full px-3 py-2 text-left text-xs font-semibold rounded-md flex items-center gap-2 transition-all duration-200">
        <span class="text-muted">#</span> faculty-q-a
      </button>
      <button data-channel="aesthetics" class="channel-btn w-full px-3 py-2 text-left text-xs font-semibold rounded-md flex items-center gap-2 transition-all duration-200">
        <span class="text-muted">#</span> ui-aesthetics
      </button>
      <button data-channel="study" class="channel-btn w-full px-3 py-2 text-left text-xs font-semibold rounded-md flex items-center gap-2 transition-all duration-200">
        <span class="text-muted">#</span> exam-prep-group
      </button>
    </div>
  </div>

  <!-- Main Chat Panel -->
  <div class="flex-1 flex flex-col h-2/3 md:h-full bg-surface-card">
    <!-- Chat Header -->
    <div class="px-5 py-3 border-b border-hairline flex items-center justify-between">
      <div>
        <h4 id="active-channel-name" class="text-sm font-semibold text-ink"># general-chat</h4>
        <p id="active-channel-desc" class="text-[11px] text-muted mt-0.5">Global discussion space for all students and professors.</p>
      </div>
      <span id="chat-member-count" class="text-[10px] font-bold text-muted bg-canvas-soft border border-hairline px-2 py-0.5 rounded-md">84 online</span>
    </div>

    <!-- Messages View -->
    <div id="messages-container" class="flex-1 overflow-y-auto p-5 flex flex-col gap-4 scroll-smooth transition-all duration-300">
      <!-- Rendered client-side -->
    </div>

    <!-- Live typing dots indicator -->
    <div id="typing-indicator" class="px-5 py-2 border-t border-transparent text-xs text-muted flex items-center gap-1.5 hidden bg-canvas-soft/10">
      <span id="typing-username" class="font-semibold text-body-strong">Dr. Arthur Pendelton</span> is typing
      <div class="flex gap-1 items-center ml-1">
        <span class="w-1.5 h-1.5 rounded-full bg-muted animate-bounce" style="animation-delay: 0ms;"></span>
        <span class="w-1.5 h-1.5 rounded-full bg-muted animate-bounce" style="animation-delay: 150ms;"></span>
        <span class="w-1.5 h-1.5 rounded-full bg-muted animate-bounce" style="animation-delay: 300ms;"></span>
      </div>
    </div>

    <!-- Input Form -->
    <div class="p-4 border-t border-hairline bg-canvas-soft/30">
      <form id="chat-input-form" class="flex items-center gap-2">
        <input type="text" id="chat-msg-input" placeholder="Message #general-chat..." required autocomplete="off" class="flex-1 px-4 py-2 border border-hairline rounded-md text-sm text-ink bg-surface-card focus:outline-none focus:border-primary transition-all duration-200" />
        <button type="submit" class="btn-primary btn-press h-9 w-9 p-0 flex items-center justify-center rounded-md">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="w-4 h-4"><line x1="22" x2="11" y1="2" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
        </button>
      </form>
    </div>
  </div>

</div>

<style>
  /* Stylings specific to Chat module */
  .channel-btn {
    background-color: transparent;
    color: var(--color-body);
  }
  .channel-btn:hover {
    background-color: var(--color-hairline-soft);
    color: var(--color-ink);
  }
  .channel-btn.active {
    background-color: var(--color-ink);
    color: var(--color-canvas);
  }
  .channel-btn.active span {
    color: var(--color-primary);
  }
</style>

<script>
  import { io } from 'socket.io-client';

  // Mock Database for Channels
  interface ChatMessage {
    id?: string;
    sender: string;
    role: 'student' | 'faculty';
    avatarBg: string;
    content: string;
    time: string;
  }

  const channelsData: Record<string, { desc: string, members: string, messages: ChatMessage[] }> = {
    general: {
      desc: "Global discussion space for all students and professors.",
      members: "84 online",
      messages: [
        { sender: "Alex Mercer", role: "student", avatarBg: "bg-timeline-read", content: "Hey everyone! Has anyone checked the exam schedule posted on the notice board?", time: "2:10 PM" },
        { sender: "Sarah Jenkins", role: "student", avatarBg: "bg-timeline-thinking", content: "Yes! Library timing extension starting next week is an absolute life-saver.", time: "2:12 PM" },
        { sender: "Prof. Evelyn Vance", role: "faculty", avatarBg: "bg-timeline-edit", content: "Make sure you clear your dues first, Sarah. Good luck with exam preparations!", time: "2:15 PM" }
      ]
    },
    'q-and-a': {
      desc: "Academic clarifications and faculty discussion board.",
      members: "25 online",
      messages: [
        { sender: "Nikhil Sharma", role: "student", avatarBg: "bg-timeline-grep", content: "Hello Prof. Vance, will the Machine Learning final include the backpropagation derivation question?", time: "11:05 AM" },
        { sender: "Prof. Evelyn Vance", role: "faculty", avatarBg: "bg-timeline-edit", content: "Yes Nikhil, understanding the math behind backpropagation is crucial. Expect at least one theoretical derivation.", time: "11:20 AM" }
      ]
    },
    aesthetics: {
      desc: "Visual design discussions, animations, and frontend guidelines.",
      members: "14 online",
      messages: [
        { sender: "David Lee", role: "student", avatarBg: "bg-timeline-done", content: "Working on the new dashboard interface! The custom cursors make transitions look extremely fluid.", time: "1:40 PM" },
        { sender: "Alex Mercer", role: "student", avatarBg: "bg-timeline-read", content: "Agree, styling with Tailwind v4 `@theme` variables is super clean.", time: "1:43 PM" }
      ]
    },
    study: {
      desc: "Student-run study groups and shared study tips.",
      members: "38 online",
      messages: [
        { sender: "Jane Doe", role: "student", avatarBg: "bg-timeline-thinking", content: "Who is up for a group study session on Discrete Math tomorrow morning?", time: "Yesterday" },
        { sender: "Marcus Aurel", role: "student", avatarBg: "bg-timeline-grep", content: "I'm in! We should go through the graph theory cheatsheet uploaded in the study materials directory.", time: "Yesterday" }
      ]
    }
  };

  // Bot Auto-Replies configuration
  const botReplies: Record<string, string[]> = {
    general: [
      "Don't forget to submit your lab records by tomorrow afternoon!",
      "I'm currently studying in the library, the extended study space is really quiet.",
      "Are there any upcoming sports events scheduled this semester?",
      "Good luck to everyone preparing for midterms!"
    ],
    'q-and-a': [
      "My office hours are between 2 PM to 4 PM on Wednesdays. Please schedule slots online.",
      "The reference syllabus has been uploaded to the dashboard under Study Materials.",
      "Yes, the lecture notes cover all examination topics comprehensively."
    ],
    aesthetics: [
      "Always ensure CSS-first transition scales do not exceed 60fps for mobile render passes.",
      "The warm cream `#f7f7f4` palette gives developer hubs an editorial, premium look.",
      "Try adding magnetic offset events to make layouts interactive.",
      "I'm testing custom cursor trails! It adds a beautiful dynamic feedback layers."
    ],
    study: [
      "Let's meet in Room 304, it has an interactive whiteboard.",
      "Let's cover relations, logic proofs, and graph colorings.",
      "Check the study notes uploaded by Dr. Pendelton. They are excellent summary items."
    ]
  };

  const API_URL = 'http://localhost:3000/api/chat';
  const SOCKET_URL = 'http://localhost:3000';

  let activeChannel = 'general';
  let socket: any = null;
  let isOffline = false;

  // Initialize socket connection
  const initSocket = () => {
    if (socket) return;
    try {
      socket = io(SOCKET_URL, {
        transports: ['websocket'],
        reconnectionAttempts: 2,
        timeout: 3000
      });

      socket.on('connect', () => {
        console.log('Chat socket connected!');
        isOffline = false;
        socket.emit('join-channel', activeChannel);
      });

      socket.on('connect_error', () => {
        isOffline = true;
      });

      socket.on('new-message', (message: any) => {
        if (message.channel === activeChannel) {
          const exists = channelsData[activeChannel].messages.some(m => m.id === message.id);
          if (!exists) {
            channelsData[activeChannel].messages.push({
              id: message.id,
              sender: message.sender,
              role: message.role === 'faculty' ? 'faculty' : 'student',
              avatarBg: message.avatarBg,
              content: message.content,
              time: message.time
            });
            renderMessages();
          }
        }
      });

      socket.on('user-typing', (data: { username: string, isTyping: boolean }) => {
        const typingBox = document.getElementById('typing-indicator');
        const typingName = document.getElementById('typing-username');
        if (!typingBox || !typingName) return;

        if (data.isTyping) {
          typingName.textContent = data.username;
          typingBox.classList.remove('hidden');
          const container = document.getElementById('messages-container');
          if (container) container.scrollTop = container.scrollHeight;
        } else {
          typingBox.classList.add('hidden');
        }
      });
    } catch (e) {
      console.warn('Socket connect failed, running in offline mode:', e);
      isOffline = true;
    }
  };

  // Fetch chat history from DB
  const fetchHistory = async (channel: string) => {
    try {
      const token = localStorage.getItem('cc-token');
      const headers: Record<string, string> = {};
      if (token) {
        headers['Authorization'] = `Bearer ${token}`;
      }
      const res = await fetch(`${API_URL}/${channel}`, { headers });
      if (!res.ok) throw new Error('HTTP error');
      const messages = await res.json();
      if (messages && messages.length > 0) {
        channelsData[channel].messages = messages.map((msg: any) => ({
          id: msg.id,
          sender: msg.sender,
          role: msg.role === 'faculty' || msg.role === 'professor' ? 'faculty' : (msg.role === 'admin' ? 'admin' : 'student'),
          avatarBg: msg.avatarBg,
          content: msg.content,
          time: msg.time
        }));
      }
    } catch (err) {
      console.warn(`Could not load chat history for ${channel} from server:`, err);
    }
  };

  // Format short current time e.g. "3:42 PM"
  const getFormattedTime = () => {
    const d = new Date();
    let hrs = d.getHours();
    const mins = String(d.getMinutes()).padStart(2, '0');
    const ampm = hrs >= 12 ? 'PM' : 'AM';
    hrs = hrs % 12;
    hrs = hrs ? hrs : 12; // 12 instead of 0
    return `${hrs}:${mins} ${ampm}`;
  };

  // Render active messages
  const renderMessages = () => {
    const container = document.getElementById('messages-container');
    if (!container) return;

    const data = channelsData[activeChannel];
    if (!data) return;

    container.innerHTML = data.messages.map((m, index) => {
      const isFaculty = m.role === 'faculty' || m.role === 'professor';
      const isAdmin = m.role === 'admin';
      const roleBadge = isAdmin
        ? `<span class="px-1.5 py-0.2 bg-timeline-done/10 border border-timeline-done/20 text-timeline-done rounded-md text-[9px] font-bold">Admin</span>`
        : isFaculty 
          ? `<span class="px-1.5 py-0.2 bg-primary/10 border border-primary/20 text-primary rounded-md text-[9px] font-bold">Faculty</span>`
          : `<span class="px-1.5 py-0.2 bg-surface-strong/60 border border-hairline text-ink rounded-md text-[9px] font-semibold">Student</span>`;
      const staggerDelay = Math.min(index * 60, 500);
        
      return `
        <div class="message-bubble flex gap-3.5 max-w-[85%] animate-chat-appear" style="animation-delay: ${staggerDelay}ms; animation-fill-mode: backwards;">
          <!-- Avatar Icon -->
          <div class="w-8 h-8 rounded-full ${m.avatarBg} text-ink font-bold flex items-center justify-center text-xs flex-shrink-0">
            ${m.sender.split(' ').map(n => n[0]).join('')}
          </div>
          
          <!-- Content Bubble -->
          <div class="flex flex-col gap-1">
            <div class="flex items-center gap-2">
              <span class="text-xs font-semibold text-body-strong">${m.sender}</span>
              ${roleBadge}
              <span class="text-[10px] text-muted">${m.time}</span>
            </div>
            
            <div class="bg-canvas-soft border border-hairline-soft px-4 py-2.5 rounded-lg text-sm text-ink leading-relaxed">
              ${m.content}
            </div>
          </div>
        </div>
      `;
    }).join('');

    // Scroll to bottom
    container.scrollTop = container.scrollHeight;
  };

  // Channel switching controller
  const setupChannelSelector = () => {
    const list = document.getElementById('channel-list');
    const title = document.getElementById('active-channel-name');
    const desc = document.getElementById('active-channel-desc');
    const count = document.getElementById('chat-member-count');
    const input = document.getElementById('chat-msg-input') as HTMLInputElement;

    if (!list || !title || !desc || !count || !input) return;

    const buttons = list.querySelectorAll('.channel-btn');
    buttons.forEach((btn: any) => {
      btn.addEventListener('click', async () => {
        const chan = btn.getAttribute('data-channel');
        if (!chan || chan === activeChannel) return;

        activeChannel = chan;

        // Emit channel join to socket.io
        if (socket && !isOffline) {
          socket.emit('join-channel', activeChannel);
        }

        // Visual highlights
        buttons.forEach((b: any) => b.classList.remove('active'));
        btn.classList.add('active');

        // Text changes
        const data = channelsData[activeChannel];
        title.innerHTML = `<span class="text-muted">#</span> ${btn.textContent.trim().split(' ').pop()}`;
        desc.textContent = data.desc;
        count.textContent = data.members;
        input.placeholder = `Message ${btn.textContent.trim()}...`;

        // Render messages with cross-fade
        const container = document.getElementById('messages-container');
        if (container) {
          container.style.opacity = '0';
          container.style.transform = 'translateY(4px)';
          
          await fetchHistory(activeChannel);
          
          setTimeout(() => {
            renderMessages();
            container.style.opacity = '1';
            container.style.transform = 'translateY(0)';
          }, 200);
        }
      });
    });
  };

  // Bot simulated responses
  const triggerBotReply = () => {
    const typingBox = document.getElementById('typing-indicator');
    const typingName = document.getElementById('typing-username');
    if (!typingBox || !typingName) return;

    const currentRole = localStorage.getItem('cc-active-role') || 'student';
    
    // Choose sender name
    const sender = (currentRole === 'professor' || currentRole === 'admin') 
      ? "Alex Mercer" 
      : "Prof. Evelyn Vance";
    const role = (currentRole === 'professor' || currentRole === 'admin') ? 'student' : 'faculty';
    const avatarBg = (currentRole === 'professor' || currentRole === 'admin') ? 'bg-timeline-read' : 'bg-timeline-edit';

    typingName.textContent = sender;
    
    // Delay typing start
    setTimeout(() => {
      typingBox.classList.remove('hidden');
      const messagesContainer = document.getElementById('messages-container');
      if (messagesContainer) {
        messagesContainer.scrollTop = messagesContainer.scrollHeight;
      }

      // Delay message delivery (simulated typing duration)
      setTimeout(() => {
        typingBox.classList.add('hidden');

        // Grab bank replies
        const replies = botReplies[activeChannel] || botReplies.general;
        const randReply = replies[Math.floor(Math.random() * replies.length)];

        channelsData[activeChannel].messages.push({
          sender,
          role: role === 'faculty' ? 'faculty' : 'student',
          avatarBg,
          content: randReply,
          time: getFormattedTime()
        });

        renderMessages();
      }, 1800);
    }, 1000);
  };

  // Send message action
  const setupMessageSubmit = () => {
    const form = document.getElementById('chat-input-form') as HTMLFormElement;
    const input = document.getElementById('chat-msg-input') as HTMLInputElement;
    if (!form || !input) return;

    form.addEventListener('submit', (e) => {
      e.preventDefault();
      const text = input.value.trim();
      if (!text) return;

      const userStr = localStorage.getItem('cc-user');
      let sender = 'Anonymous';
      let senderId = '';
      let role = 'student';
      let avatarBg = 'bg-timeline-read';

      if (userStr) {
        try {
          const user = JSON.parse(userStr);
          sender = user.name || sender;
          senderId = user.id || '';
          role = user.role || role;
        } catch {}
      }

      if (role === 'admin') {
        avatarBg = 'bg-timeline-done';
      } else if (role === 'professor') {
        avatarBg = 'bg-timeline-edit';
      } else {
        avatarBg = 'bg-timeline-read';
      }

      const payload = {
        channel: activeChannel,
        sender,
        role,
        avatarBg,
        content: text,
        time: getFormattedTime(),
        senderId
      };

      if (socket && !isOffline) {
        socket.emit('send-message', payload);
      } else {
        // Offline backup
        channelsData[activeChannel].messages.push(payload);
        renderMessages();
        triggerBotReply();
      }

      input.value = '';
    });
  };

  // Typing indicators notifier
  const setupTypingNotifier = () => {
    const input = document.getElementById('chat-msg-input') as HTMLInputElement;
    if (!input) return;

    let typingTimeout: any = null;

    input.addEventListener('input', () => {
      if (!socket || isOffline) return;

      const userStr = localStorage.getItem('cc-user');
      let sender = 'Anonymous';
      if (userStr) {
        try {
          const user = JSON.parse(userStr);
          sender = user.name || sender;
        } catch {}
      }

      if (typingTimeout) clearTimeout(typingTimeout);

      socket.emit('typing', {
        channel: activeChannel,
        username: sender,
        isTyping: true
      });

      typingTimeout = setTimeout(() => {
        socket.emit('typing', {
          channel: activeChannel,
          username: sender,
          isTyping: false
        });
      }, 1500);
    });
  };

  // Initialize
  const initChat = async () => {
    const root = document.getElementById('community-chat-root');
    if (!root) return;

    initSocket();
    await fetchHistory(activeChannel);
    renderMessages();
    setupChannelSelector();
    setupMessageSubmit();
    setupTypingNotifier();

    setTimeout(() => {
      root.style.opacity = '1';
      root.style.transform = 'translateY(0)';
    }, 100);
  };

  // Listeners
  window.addEventListener('load', initChat);
  
  // Custom SPA mount trigger
  window.addEventListener('cc-tab-active-chat', initChat);
</script>
