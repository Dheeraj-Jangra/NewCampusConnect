---
// Navbar Component for CampusConnect
---

<header id="main-nav" class="sticky top-0 z-50 w-full h-16 bg-canvas/80 backdrop-blur-md border-b border-hairline px-6 md:px-12 flex items-center justify-between select-none transition-all duration-300">
  <!-- Brand logo -->
  <div class="flex items-center gap-2" id="nav-brand">
    <div class="w-8 h-8 rounded-md bg-primary flex items-center justify-center text-on-primary font-bold text-lg shadow-sm transform hover:rotate-12 transition-transform duration-300">
      C
    </div>
    <span class="font-sans font-semibold tracking-tight text-lg text-ink">
      Campus<span class="text-primary">Connect</span>
    </span>
  </div>

  <!-- Role Selector Capsule -->
  <div class="relative flex items-center bg-canvas-soft border border-hairline p-1 rounded-pill h-10 w-60" id="role-selector-pill">
    <!-- Active sliding background bubble -->
    <div id="nav-indicator" class="absolute top-1 bottom-1 left-0 bg-ink rounded-pill transition-all duration-300 ease-out"></div>
    
    <button id="nav-btn-student" class="relative z-10 w-1/2 text-center text-[11px] font-semibold uppercase tracking-wider text-canvas py-1.5 transition-colors duration-300 focus:outline-none">
      Student
    </button>
    <button id="nav-btn-professor" class="relative z-10 w-1/2 text-center text-[11px] font-semibold uppercase tracking-wider text-muted py-1.5 transition-colors duration-300 focus:outline-none">
      Professor
    </button>
  </div>

  <!-- Animated User Badge -->
  <div class="flex items-center gap-3">
    <!-- Dark Mode Toggle -->
    <button id="theme-toggle" class="w-9 h-9 rounded-md bg-surface-card border border-hairline flex items-center justify-center text-muted hover:text-ink hover:border-hairline-strong transition-all duration-300" aria-label="Toggle dark mode">
      <svg id="icon-sun" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="hidden"><circle cx="12" cy="12" r="4"/><path d="M12 2v2"/><path d="M12 20v2"/><path d="m4.93 4.93 1.41 1.41"/><path d="m17.66 17.66 1.41 1.41"/><path d="M2 12h2"/><path d="M20 12h2"/><path d="m6.34 17.66-1.41 1.41"/><path d="m19.07 4.93-1.41 1.41"/></svg>
      <svg id="icon-moon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"/></svg>
    </button>

    <div id="user-badge" class="hidden sm:flex items-center gap-2 px-3 py-1 bg-surface-card border border-hairline rounded-pill transition-all duration-500 transform hover:scale-105">
      <span class="relative flex h-2 w-2">
        <span class="animate-ping-slow absolute inline-flex h-full w-full rounded-full bg-semantic-success opacity-75"></span>
        <span class="relative inline-flex rounded-full h-2 w-2 bg-semantic-success"></span>
      </span>
      <span id="user-name" class="font-sans text-xs font-medium text-body-strong">Alex Mercer (Student)</span>
    </div>
  </div>
</header>

<script>
  // ── Dark Mode Toggle ──
  const themeToggle = document.getElementById('theme-toggle');
  const iconSun = document.getElementById('icon-sun');
  const iconMoon = document.getElementById('icon-moon');
  const html = document.documentElement;

  const applyTheme = (dark: boolean) => {
    if (dark) {
      html.classList.add('dark');
      iconSun?.classList.remove('hidden');
      iconMoon?.classList.add('hidden');
    } else {
      html.classList.remove('dark');
      iconSun?.classList.add('hidden');
      iconMoon?.classList.remove('hidden');
    }
  };

  // Load saved preference (default: light)
  const savedTheme = localStorage.getItem('cc-theme');
  applyTheme(savedTheme === 'dark');

  themeToggle?.addEventListener('click', () => {
    const isDark = html.classList.toggle('dark');
    localStorage.setItem('cc-theme', isDark ? 'dark' : 'light');
    applyTheme(isDark);
  });

  // ── Role Selector ──
  const btnStudent = document.getElementById('nav-btn-student');
  const btnProfessor = document.getElementById('nav-btn-professor');
  const indicator = document.getElementById('nav-indicator');
  const userName = document.getElementById('user-name');
  const userBadge = document.getElementById('user-badge');
  const brand = document.getElementById('nav-brand');

  if (btnStudent && btnProfessor && indicator && userName) {
    // Set initial indicator position
    indicator.style.width = `${btnStudent.offsetWidth}px`;
    indicator.style.transform = `translateX(${btnStudent.offsetLeft}px)`;

    const setRole = (role: 'student' | 'professor', publishEvent = true) => {
      // Save to localStorage
      localStorage.setItem('cc-active-role', role);
      
      // Update UI classes
      if (role === 'student') {
        indicator.style.width = `${btnStudent.offsetWidth}px`;
        indicator.style.transform = `translateX(${btnStudent.offsetLeft}px)`;
        btnStudent.classList.remove('text-muted');
        btnStudent.classList.add('text-canvas');
        btnProfessor.classList.remove('text-canvas');
        btnProfessor.classList.add('text-muted');
        
        // Dynamic text swap with slide transition
        if (userBadge) {
          userBadge.style.transform = 'scale(0.9) translateY(5px)';
          userBadge.style.opacity = '0';
          setTimeout(() => {
            userName.textContent = 'Alex Mercer (Student)';
            userBadge.style.transform = 'scale(1) translateY(0)';
            userBadge.style.opacity = '1';
          }, 200);
        }
      } else {
        indicator.style.width = `${btnProfessor.offsetWidth}px`;
        indicator.style.transform = `translateX(${btnProfessor.offsetLeft}px)`;
        
        btnProfessor.classList.remove('text-muted');
        btnProfessor.classList.add('text-canvas');
        btnStudent.classList.remove('text-canvas');
        btnStudent.classList.add('text-muted');
        
        if (userBadge) {
          userBadge.style.transform = 'scale(0.9) translateY(5px)';
          userBadge.style.opacity = '0';
          setTimeout(() => {
            userName.textContent = 'Prof. Evelyn Vance';
            userBadge.style.transform = 'scale(1) translateY(0)';
            userBadge.style.opacity = '1';
          }, 200);
        }
      }

      if (publishEvent) {
        // Dispatch global custom event
        window.dispatchEvent(new CustomEvent('cc-role-changed', { detail: { role } }));
      }
    };

    // Click events
    btnStudent.addEventListener('click', () => setRole('student'));
    btnProfessor.addEventListener('click', () => setRole('professor'));
    
    // Logo resets role to student / triggers redirect to welcome splash if we want
    brand?.addEventListener('click', () => {
      window.dispatchEvent(new CustomEvent('cc-go-home'));
    });

    // Check localStorage on load
    window.addEventListener('load', () => {
      const storedRole = localStorage.getItem('cc-active-role') as 'student' | 'professor';
      if (storedRole) {
        setRole(storedRole, false);
      }
    });

    // Support listener if updated elsewhere (e.g. from splash screen cards)
    window.addEventListener('cc-role-selected-init', (e: any) => {
      if (e.detail && e.detail.role) {
        setRole(e.detail.role, false);
      }
    });
  }

  // ── Scroll-aware backdrop deepening ──
  const mainNav = document.getElementById('main-nav');
  if (mainNav) {
    let ticking = false;
    window.addEventListener('scroll', () => {
      if (!ticking) {
        requestAnimationFrame(() => {
          const scrolled = window.scrollY > 20;
          if (scrolled) {
            mainNav.style.backgroundColor = 'color-mix(in srgb, var(--color-canvas) 92%, transparent)';
            mainNav.style.backdropFilter = 'blur(16px)';
            mainNav.style.boxShadow = '0 1px 3px rgba(38, 37, 30, 0.04)';
          } else {
            mainNav.style.backgroundColor = '';
            mainNav.style.backdropFilter = '';
            mainNav.style.boxShadow = '';
          }
          ticking = false;
        });
        ticking = true;
      }
    });
  }
</script>
