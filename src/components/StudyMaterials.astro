---
// Study Materials Component
---

<div id="study-materials-root" class="w-full flex-1 flex flex-col gap-6 opacity-0 translate-y-4 transition-all duration-500">
  
  <!-- Subheader & Search Bar -->
  <div class="flex flex-col md:flex-row md:items-center justify-between gap-4 border-b border-hairline pb-6">
    <div>
      <h2 class="display-md text-ink">Study Materials Library</h2>
      <p class="body-sm text-muted">Lecture notes, syllabus copies, and recommended readings.</p>
    </div>

    <!-- Search Input -->
    <div class="relative w-full md:w-80">
      <input type="text" id="materials-search" placeholder="Search materials by name or course..." class="w-full px-4 py-2 pl-10 bg-surface-card border border-hairline rounded-md text-sm text-ink focus:outline-none focus:border-primary transition-all duration-200" />
      <div class="absolute left-3.5 top-1/2 -translate-y-1/2 text-muted">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-4 h-4"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
      </div>
    </div>
  </div>

  <!-- Content Split -->
  <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-start">
    
    <!-- Professor Panel: Drag & Drop Upload Simulator -->
    <div id="materials-professor-panel" class="lg:col-span-4 bg-surface-card border border-hairline rounded-lg p-6 flex flex-col gap-4 hidden animated-mount">
      <div class="flex items-center justify-between border-b border-hairline pb-3">
        <h3 class="title-md text-ink">Upload Resource</h3>
        <span class="px-2 py-0.5 text-[9px] font-bold uppercase tracking-wider text-timeline-done border border-timeline-done/20 rounded-pill" style="background: rgba(192, 133, 50, 0.12);">Professor Mode</span>
      </div>

      <form id="upload-form" class="flex flex-col gap-4">
        <!-- Title -->
        <div class="flex flex-col gap-1.5">
          <label for="material-title" class="text-xs font-semibold text-body-strong">Material Title</label>
          <input type="text" id="material-title" placeholder="e.g. Lecture 12: Neural Nets Intro" required class="w-full px-3 py-2 bg-canvas-soft border border-hairline rounded-md text-sm text-ink focus:outline-none focus:border-primary transition-all duration-200" />
        </div>

        <!-- Subject Course Tag -->
        <div class="flex flex-col gap-1.5">
          <label for="material-course" class="text-xs font-semibold text-body-strong">Course Code</label>
          <select id="material-course" required class="w-full px-3 py-2 bg-canvas-soft border border-hairline rounded-md text-sm text-ink focus:outline-none focus:border-primary transition-all duration-200">
            <option value="CS-101">CS-101 (Intro to CS)</option>
            <option value="CS-402">CS-402 (Advanced UI Design)</option>
            <option value="MATH-202">MATH-202 (Discrete Algebra)</option>
            <option value="ELEC-301">ELEC-301 (Embedded Systems)</option>
          </select>
        </div>

        <!-- Drag and Drop Box Simulator -->
        <div id="drop-zone" class="border-2 border-dashed border-hairline-strong rounded-lg p-6 text-center hover:border-primary/50 hover:border-flow transition-all duration-300 flex flex-col items-center justify-center gap-2 bg-canvas-soft/40 relative overflow-hidden group">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-muted w-8 h-8 group-hover:animate-float-gentle group-hover:text-primary transition-colors duration-300"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" x2="12" y1="3" y2="15"/></svg>
          <div>
            <span class="text-xs font-semibold text-ink block">Click or Drop PDF / ZIP here</span>
            <span class="text-[10px] text-muted block mt-0.5">Maximum size: 50MB</span>
          </div>
          <!-- Hidden real file input -->
          <input type="file" id="material-file" class="absolute inset-0 opacity-0" />
          
          <!-- File selection overlay -->
          <div id="selected-file-overlay" class="absolute inset-0 bg-surface-card flex flex-col items-center justify-center p-4 hidden">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-timeline-grep w-8 h-8"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><polyline points="14 2 14 8 20 8"/></svg>
            <span id="selected-file-name" class="text-xs font-semibold text-ink mt-2 truncate w-full max-w-[180px]">filename.pdf</span>
            <button type="button" id="remove-file-btn" class="text-[10px] text-semantic-error font-semibold hover:underline mt-1 focus:outline-none">Remove</button>
          </div>
        </div>

        <!-- Progress Bar Indicator -->
        <div id="upload-progress-container" class="flex flex-col gap-1 hidden">
          <div class="flex items-center justify-between text-[10px] font-bold uppercase tracking-wider text-muted">
            <span id="upload-progress-label">Uploading...</span>
            <span id="upload-progress-percent">0%</span>
          </div>
          <div class="w-full h-1.5 bg-canvas-soft rounded-full overflow-hidden border border-hairline">
            <div id="upload-progress-bar" class="w-0 h-full bg-timeline-grep transition-all duration-300 ease-out shimmer-overlay"></div>
          </div>
        </div>

        <!-- Submit Button -->
        <button type="submit" id="upload-submit-btn" class="btn-primary btn-press ripple-container w-full mt-2 flex items-center justify-center gap-2">
          <span>Upload File</span>
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="w-3.5 h-3.5"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </button>
      </form>
    </div>

    <!-- Materials Browser List -->
    <div id="materials-browser" class="lg:col-span-12 flex flex-col gap-4">
      <div id="no-materials-alert" class="hidden text-center py-12 border border-dashed border-hairline rounded-lg bg-surface-card/50">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="mx-auto text-muted w-8 h-8 mb-2 animate-bounce"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><polyline points="14 2 14 8 20 8"/></svg>
        <span class="text-sm font-semibold text-ink">No materials found</span>
        <p class="text-xs text-muted mt-1">Refine your search or upload documents.</p>
      </div>

      <div id="materials-list-container" class="flex flex-col gap-3">
        <!-- Rendered client-side -->
      </div>
    </div>

  </div>
</div>

<script>
  // HTML sanitization to prevent XSS
  const escapeHtml = (str: string) => {
    if (!str) return '';
    const map: Record<string, string> = { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#x27;', '/': '&#x2F;' };
    return String(str).replace(/[&<>"'/]/g, (c) => map[c] || c);
  };

  // Validate URL to block javascript: and data: protocols
  const sanitizeUrl = (url: string) => {
    if (!url) return '#';
    const t = url.trim().toLowerCase();
    if (t.startsWith('javascript:') || t.startsWith('data:') || t.startsWith('vbscript:')) return '#';
    return url;
  };

  import { API_BASE } from '../lib/api';
  const API_URL = `${API_BASE}/api/materials`;
  let searchQuery = '';
  let currentRole: string = 'student';

  // Delete a material resource
  const deleteMaterial = async (id: string) => {
    const token = localStorage.getItem('cc-token');
    try {
      const headers: Record<string, string> = {};
      if (token) headers['Authorization'] = `Bearer ${token}`;
      const res = await fetch(`${API_URL}/${id}`, { method: 'DELETE', headers });
      if (!res.ok) {
        const body = await res.json().catch(() => ({}));
        throw new Error(body.error || `Failed with status ${res.status}`);
      }
      window.dispatchEvent(new CustomEvent('cc-toast-alert', { detail: { message: 'Material deleted successfully', type: 'success' } }));
      await renderMaterials();
      window.dispatchEvent(new CustomEvent('cc-materials-changed'));
    } catch (err: any) {
      console.error('Failed to delete material:', err?.message || err);
      window.dispatchEvent(new CustomEvent('cc-toast-alert', { detail: { message: err?.message || 'Failed to delete material', type: 'error' } }));
    }
  };

  const getMaterials = async () => {
    const token = localStorage.getItem('cc-token');
    const headers: Record<string, string> = {};
    if (token) {
      headers['Authorization'] = `Bearer ${token}`;
    }
    const res = await fetch(API_URL, { headers });
    if (!res.ok) throw new Error('Failed to fetch materials from API');
    return res.json();
  };

  // Render materials list
  const renderMaterials = async () => {
    const listContainer = document.getElementById('materials-list-container');
    const noMaterialsAlert = document.getElementById('no-materials-alert');
    if (!listContainer || !noMaterialsAlert) return;

    currentRole = localStorage.getItem('cc-active-role') || 'student';
    const materialsList = await getMaterials();
    const sortedMaterials = materialsList.sort((a: any, b: any) => new Date(b.timestamp).getTime() - new Date(a.timestamp).getTime());
    
    // Filter by search query
    const filtered = sortedMaterials.filter((m: any) => {
      const q = searchQuery.toLowerCase();
      return m.title.toLowerCase().includes(q) || m.course.toLowerCase().includes(q);
    });

    if (filtered.length === 0) {
      noMaterialsAlert.classList.remove('hidden');
      listContainer.innerHTML = '';
      return;
    } else {
      noMaterialsAlert.classList.add('hidden');
    }

    listContainer.innerHTML = filtered.map((m: any, index: number) => {
      // Icon selection based on file extension
      let icon = '';
      const type = m.type ? m.type.toLowerCase() : 'pdf';
      if (type === 'pdf') {
        icon = `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-semantic-error w-5 h-5"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><polyline points="14 2 14 8 20 8"/></svg>`;
      } else if (type === 'zip' || type === 'rar') {
        icon = `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-timeline-done w-5 h-5"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><path d="M7 10h10"/><path d="M12 10v4"/><path d="M12 2v4"/></svg>`;
      } else {
        // generic file
        icon = `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-timeline-read w-5 h-5"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><polyline points="14 2 14 8 20 8"/><line x1="8" y1="13" x2="16" y2="13"/><line x1="8" y1="17" x2="16" y2="17"/></svg>`;
      }

      const staggerDelay = Math.min(index * 50, 400);

      return `
        <div class="material-row bg-surface-card border border-hairline rounded-lg p-4 flex items-center justify-between gap-4 hover:border-hairline-strong hover-lift transition-all duration-300 animate-fade-in-up" data-id="${escapeHtml(m.id)}" style="animation-delay: ${staggerDelay}ms; animation-fill-mode: backwards;">
          <div class="flex items-center gap-3.5 min-w-0">
            <div class="p-2.5 bg-canvas-soft border border-hairline-soft rounded-md transition-all duration-300 hover:scale-110 hover:rotate-6">
              ${icon}
            </div>
            <div class="min-w-0">
              <h4 class="text-sm font-semibold text-ink line-clamp-1">${escapeHtml(m.title)}</h4>
              <div class="flex items-center gap-2 flex-wrap text-xs text-muted mt-0.5">
                <span class="px-2 py-0.2 bg-surface-strong/50 border border-hairline text-ink rounded-md text-[10px] font-bold">${escapeHtml(m.course)}</span>
                <span>&bull;</span>
                <span>Size: ${escapeHtml(m.size)}</span>
                <span>&bull;</span>
                <span>Uploaded by: ${escapeHtml(m.author)}</span>
              </div>
            </div>
          </div>
          
          <div class="flex items-center gap-1">
            <button data-id="${escapeHtml(m.id)}" class="download-btn btn-secondary btn-press flex items-center gap-1.5 text-xs py-1.5 h-8 hover:scale-105 transition-transform duration-200">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="w-3.5 h-3.5"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" x2="12" y1="15" y2="3"/></svg>
              <span>Download</span>
            </button>
            <button data-id="${escapeHtml(m.id)}" class="material-delete-btn p-1.5 rounded-md text-muted hover:text-semantic-error hover:bg-semantic-error/10 transition-all duration-200 ${currentRole === 'professor' || currentRole === 'admin' ? '' : 'hidden'}" title="Delete material">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-3.5 h-3.5"><path d="M3 6h18"/><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"/><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/></svg>
            </button>
          </div>
        </div>
      `;
    }).join('');

    // Attach animated download triggers
    const downloadBtns = listContainer.querySelectorAll('.download-btn');
    downloadBtns.forEach((btn: any) => {
      btn.addEventListener('click', () => {
        const id = btn.getAttribute('data-id');
        const span = btn.querySelector('span');
        const icon = btn.querySelector('svg');
        if (!span || !icon || !id) return;

        span.textContent = 'Downloading...';
        
        const downloadUrl = `${API_URL}/download/${id}`;
        const anchor = document.createElement('a');
        anchor.href = downloadUrl;
        anchor.target = '_blank';
        anchor.click();
        
        setTimeout(() => {
          span.textContent = 'Downloaded';
          btn.style.backgroundColor = 'var(--color-semantic-success)';
          btn.style.color = 'var(--color-on-primary)';
          btn.style.borderColor = 'var(--color-semantic-success)';
          btn.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="w-3.5 h-3.5 text-white"><path d="M20 6 9 17l-5-5"/></svg> <span>Downloaded</span>`;
          
          window.dispatchEvent(new CustomEvent('cc-toast-alert', { 
            detail: { message: 'Resource downloaded from server!', type: 'success' } 
          }));

          setTimeout(() => {
            btn.disabled = false;
            btn.style.backgroundColor = '';
            btn.style.color = '';
            btn.style.borderColor = '';
            btn.innerHTML = `
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="w-3.5 h-3.5"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" x2="12" y1="15" y2="3"/></svg>
              <span>Download</span>
            `;
          }, 2000);
        }, 1000);
      });
    });

    // Attach delete handlers
    const deleteBtns = listContainer.querySelectorAll('.material-delete-btn');
    deleteBtns.forEach((btn: any) => {
      btn.addEventListener('click', async (e: MouseEvent) => {
        e.stopPropagation();
        const id = btn.getAttribute('data-id');
        if (!id) return;
        if (!confirm('Delete this material? This action cannot be undone.')) return;
        btn.disabled = true;
        btn.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-3.5 h-3.5 animate-spin"><path d="M21 12a9 9 0 1 1-6.219-8.56"/></svg>`;
        await deleteMaterial(id);
      });
    });
  };

  // Setup file upload events
  const setupUploadForm = () => {
    const form = document.getElementById('upload-form') as HTMLFormElement;
    const dropZone = document.getElementById('drop-zone');
    const fileInput = document.getElementById('material-file') as HTMLInputElement;
    const overlay = document.getElementById('selected-file-overlay');
    const overlayName = document.getElementById('selected-file-name');
    const removeBtn = document.getElementById('remove-file-btn');
    const submitBtn = document.getElementById('upload-submit-btn') as HTMLButtonElement;
    
    // Progress refs
    const progressContainer = document.getElementById('upload-progress-container');
    const progressBar = document.getElementById('upload-progress-bar');
    const progressPercent = document.getElementById('upload-progress-percent');
    
    if (!form || !dropZone || !fileInput || !overlay || !overlayName || !removeBtn || !submitBtn || !progressContainer || !progressBar || !progressPercent) return;

    let selectedFile: File | null = null;

    const handleFileSelected = (file: File) => {
      selectedFile = file;
      overlayName.textContent = file.name;
      overlay.classList.remove('hidden');
    };

    // File input changes
    fileInput.addEventListener('change', () => {
      if (fileInput.files && fileInput.files.length > 0) {
        handleFileSelected(fileInput.files[0]);
      }
    });

    // Remove file selection
    removeBtn.addEventListener('click', (e) => {
      e.stopPropagation();
      selectedFile = null;
      fileInput.value = '';
      overlay.classList.add('hidden');
    });

    // Drag-over styling
    dropZone.addEventListener('dragover', (e) => {
      e.preventDefault();
      dropZone.classList.add('border-primary');
    });

    dropZone.addEventListener('dragleave', () => {
      dropZone.classList.remove('border-primary');
    });

    dropZone.addEventListener('drop', (e: DragEvent) => {
      e.preventDefault();
      dropZone.classList.remove('border-primary');
      if (e.dataTransfer && e.dataTransfer.files.length > 0) {
        handleFileSelected(e.dataTransfer.files[0]);
      }
    });

    form.addEventListener('submit', (e) => {
      e.preventDefault();

      const titleInput = document.getElementById('material-title') as HTMLInputElement;
      const courseSelect = document.getElementById('material-course') as HTMLSelectElement;

      if (!titleInput || !courseSelect) return;

      const title = titleInput.value.trim();
      const course = courseSelect.value;

      if (!title) return;
      if (!selectedFile) {
        window.dispatchEvent(new CustomEvent('cc-toast-alert', { 
          detail: { message: 'Please select a file to upload', type: 'warning' } 
        }));
        return;
      }

      submitBtn.disabled = true;
      progressContainer.classList.remove('hidden');
      progressBar.style.width = '0%';
      progressPercent.textContent = '0%';

      const userStr = localStorage.getItem('cc-user');
      let author = 'Faculty Member';
      if (userStr) {
        try {
          const user = JSON.parse(userStr);
          author = user.name || author;
        } catch {}
      }

      const formData = new FormData();
      formData.append('title', title);
      formData.append('course', course);
      formData.append('author', author);
      formData.append('file', selectedFile);

      const xhr = new XMLHttpRequest();
      xhr.open('POST', `${API_URL}/upload`, true);

      const token = localStorage.getItem('cc-token');
      if (token) {
        xhr.setRequestHeader('Authorization', `Bearer ${token}`);
      }

      xhr.upload.onprogress = (event) => {
        if (event.lengthComputable) {
          const percent = Math.round((event.loaded / event.total) * 100);
          progressBar.style.width = `${percent}%`;
          progressPercent.textContent = `${percent}%`;
        }
      };

      xhr.onload = () => {
        if (xhr.status === 200 || xhr.status === 201) {
          window.dispatchEvent(new CustomEvent('cc-toast-alert', { 
            detail: { message: 'Document uploaded successfully!', type: 'success' } 
          }));
          form.reset();
          selectedFile = null;
          fileInput.value = '';
          overlay.classList.add('hidden');
          setTimeout(async () => {
            progressContainer.classList.add('hidden');
            progressBar.style.width = '0%';
            submitBtn.disabled = false;
            await renderMaterials();
            window.dispatchEvent(new CustomEvent('cc-materials-changed'));
          }, 400);
        } else {
          window.dispatchEvent(new CustomEvent('cc-toast-alert', { 
            detail: { message: 'Upload failed', type: 'error' } 
          }));
          submitBtn.disabled = false;
        }
      };

      xhr.onerror = () => {
        window.dispatchEvent(new CustomEvent('cc-toast-alert', { 
          detail: { message: 'Upload failed due to connection error', type: 'error' } 
        }));
        submitBtn.disabled = false;
      };

      xhr.send(formData);
    });
  };

  // Search logic bindings
  const setupSearch = () => {
    const searchInput = document.getElementById('materials-search') as HTMLInputElement;
    if (!searchInput) return;

    ['input', 'keyup', 'change'].forEach((evt) => {
      searchInput.addEventListener(evt, () => {
        searchQuery = searchInput.value;
        renderMaterials();
      });
    });
  };

  // Toggle layout based on active role
  const handleRoleView = (role: 'student' | 'professor' | 'admin') => {
    const profPanel = document.getElementById('materials-professor-panel');
    const browser = document.getElementById('materials-browser');
    if (!profPanel || !browser) return;

    currentRole = role;

    if (role === 'professor' || role === 'admin') {
      profPanel.classList.remove('hidden');
      browser.classList.remove('lg:col-span-12');
      browser.classList.add('lg:col-span-8');
    } else {
      profPanel.classList.add('hidden');
      browser.classList.remove('lg:col-span-8');
      browser.classList.add('lg:col-span-12');
    }

    renderMaterials();
  };

  // Initialize
  const initMaterials = () => {
    const root = document.getElementById('study-materials-root');
    if (!root) return;

    renderMaterials();
    setupUploadForm();
    setupSearch();

    const currentRole = (localStorage.getItem('cc-active-role') || 'student') as 'student' | 'professor' | 'admin';
    handleRoleView(currentRole);

    setTimeout(() => {
      root.style.opacity = '1';
      root.style.transform = 'translateY(0)';
    }, 100);
  };

  // Listeners
  window.addEventListener('cc-role-changed', (e: any) => {
    if (e.detail && e.detail.role) {
      handleRoleView(e.detail.role);
    }
  });

  window.addEventListener('cc-materials-changed', () => {
    renderMaterials();
  });

  window.addEventListener('load', initMaterials);
  
  // Custom SPA mount trigger
  window.addEventListener('cc-tab-active-materials', initMaterials);
</script>
